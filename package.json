{
  "name": "express-be-template",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --testPathIgnorePatterns=tests/integration",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js tests/integration",
    "test:integration:http": "bash -lc \"find tests/integration -type f -name '*http.int.test.js' -print0 | sort -z | xargs -0 node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand\"",
    "test:integration:service": "bash -lc \"find tests/integration -type f -name '*.int.test.js' ! -name '*http.int.test.js' -print0 | sort -z | xargs -0 node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand\"",
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development && nodemon src/server.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@google/genai": "^1.29.1",
    "@prisma/client": "^6.16.2",
    "apicache": "^1.6.3",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "groq-sdk": "^0.35.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.0",
    "jsonwebtoken": "^9.0.2",
    "midtrans-client": "^1.4.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "nodemon": "^3.1.10",
    "useragent": "^2.3.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^30.4.1",
    "prisma": "^6.16.2",
    "supertest": "^7.2.2"
  }
}
